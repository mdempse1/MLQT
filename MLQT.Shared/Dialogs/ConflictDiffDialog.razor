@using MLQT.Services.Interfaces
@using System.IO

@inject IRepositoryService RepositoryService

<MudDialog>
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
            <MudIcon Icon="@Icons.Material.Filled.CompareArrows" Size="Size.Small" />
            <MudText Typo="Typo.h6">Conflict: @Path.GetFileName(FilePath)</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        @if (_isLoading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }
        else if (_ours == null && _theirs == null)
        {
            <MudAlert Severity="Severity.Warning" Dense="true">
                Conflict versions are not available. The file may already have been resolved,
                or the conflict sidecar files could not be found.
            </MudAlert>
        }
        else
        {
            <DiffViewer OriginalContent="@(_ours ?? string.Empty)"
                        ModifiedContent="@(_theirs ?? string.Empty)"
                        FileName="@FilePath"
                        OriginalLabel="Ours (current branch)"
                        ModifiedLabel="Theirs (incoming)"
                        ViewMode="DiffViewMode.SideBySide"
                        Height="60vh" />
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => MudDialog?.Close())">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance? MudDialog { get; set; }

    [Parameter]
    public string RepositoryId { get; set; } = "";

    [Parameter]
    public string FilePath { get; set; } = "";

    private string? _ours;
    private string? _theirs;
    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        (_ours, _theirs) = await RepositoryService.GetConflictVersionsAsync(RepositoryId, FilePath);
        _isLoading = false;
    }
}
