    private void RowClickEvent(TableRowClickEventArgs<LogMessage> args)
    {
        _currentIssue = args.Item;
        if (_currentIssue == null) return;

        // Close any open spelling popover first
        _spellingPopoverOpen = false;
        _suggestions = null;

        if (IsSpellingViolation(_currentIssue))
        {
            // Show popover context menu for spelling violations
            _spellingPopoverOpen = true;
        }
        else if (!string.IsNullOrEmpty(_currentIssue.Details))
        {
            _issueDetailsVisible = true;
        }

        NavState.ChangeModelID(_currentIssue.ModelName);
    }

