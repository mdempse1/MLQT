    private void OnModelContentChanged(IReadOnlyCollection<string> modelIds)
    {
        // Remove stale cache entries so the next ChangeModelID call re-renders from fresh content
        foreach (var id in modelIds)
        {
            var keysToRemove = _renderCache.Keys.Where(k => k.ModelId == id).ToList();
            foreach (var key in keysToRemove)
                _renderCache.Remove(key);
        }
    }

    private async void LibraryLoaded()
    {
        // Clear render cache — models may have changed
        _renderCache.Clear();

        // Clear existing log messages when a new library is loaded
        CodeReviewService.ClearLogMessages();

        // Add parser errors to the issues list
        foreach (var model in LibraryDataService.GetAllModels())
        {
            if (model.Definition.ParserErrors != null && model.Definition.ParserErrors.Count > 0)
            {
                foreach (var error in model.Definition.ParserErrors)
                {
                    var issue = new LogMessage(
                    model.Definition.Name,
                    "Error",
                    error.Line,
                    "Parser error",
                    error.Message + (error.OffendingToken != null ? $" (token: '{error.OffendingToken}')" : ""));
                    CodeReviewService.AddLogMessage(issue);
                }
            }
        }

        // Update UI with parser errors before starting background style checking
        await InvokeAsync(StateHasChanged);
    }

    private string MakeShortName(string name)
    {
        var idx = name.IndexOf(".") + 1;
        return name.Length <= 40 || name.IndexOf(".") == -1 || name.Count(c => c == '.') <= 1 ?
                name :
                name.Substring(0, name.IndexOf(".", idx)) + "..." + name.Substring(name.LastIndexOf("."));
    }

    private bool FilterFunc1(LogMessage element) => FilterFunc(element, _searchString + (IssuesScopeAllModels ? " " + NavState.ModelID: "") );

    private bool FilterFunc(LogMessage element, string searchString)
    {
        if (string.IsNullOrWhiteSpace(searchString))
            return true;

        if (IssuesScopeAllModels && NavState.ModelID.Length > 0) {
            if (element.ModelName == NavState.ModelID) {
                //Remove the model name from the search string before continuing
                searchString = searchString.Replace(NavState.ModelID,"").Trim();
                if (searchString.Length > 0) {
                    var strings = searchString.ToLower().Split(' ');
                    if (element.Summary.Length > 0 && strings.Any(element.Summary.ToLower().Contains))
                        return true;
                    if (element.Details.Length > 0 && strings.Any(element.Details.ToLower().Contains))
                        return true;
                    if (element.Severity.Length > 0 && strings.Any(element.Severity.ToLower().Contains))
                        return true;
                    return false;
                }
                return true;
            }
        }
        else {
            var strings = searchString.Split(' ');
            if (strings.Any(element.ModelName.Contains))
                return true;

            var stringsLowerCase = searchString.ToLower().Split(' ');
            if (element.Summary.Length > 0 && stringsLowerCase.Any(element.Summary.ToLower().Contains))
                return true;
            if (element.Details.Length > 0 && stringsLowerCase.Any(element.Details.ToLower().Contains))
                return true;
            if (element.Severity.Length > 0 && stringsLowerCase.Any(element.Severity.ToLower().Contains))
                return true;
        }
        return false;
    }

    private void ResolveIssue()
    {
        if (_currentIssue != null)
            CodeReviewService.RemoveLogMessage(_currentIssue);
        _issueDetailsVisible = false;
        StateHasChanged();
    }

    private void OnIssuesScopeChanged(bool value) {
        IssuesScopeAllModels = value;
        StateHasChanged();
    }

    private static readonly Regex MisspelledWordRegex = new(@"^Misspelled word '([^']+)'", RegexOptions.Compiled);

    private static bool IsSpellingViolation(LogMessage? issue)
    {
        return issue?.Summary?.StartsWith("Misspelled word '") == true;
    }

    private static string? ExtractMisspelledWord(LogMessage? issue)
    {
        if (issue == null)
            return null;
        var match = MisspelledWordRegex.Match(issue.Summary);
        return match.Success ? match.Groups[1].Value : null;
    }

    private async Task AddToDictionary()
    {
        var word = ExtractMisspelledWord(_currentIssue);
        if (string.IsNullOrEmpty(word))
            return;

        await CustomDictionaryService.AddWordAsync(word);

        // Also add to the spell checker's in-memory custom words
        StyleCheckingService.GetSpellChecker()?.AddCustomWord(word);

        // Remove all violations for this word across all models
        CodeReviewService.RemoveLogMessagesByPredicate(m =>
            m.Summary == $"Misspelled word '{word}' in description" ||
            m.Summary == $"Misspelled word '{word}' in documentation info" ||
            m.Summary == $"Misspelled word '{word}' in documentation revisions");

        _spellingPopoverOpen = false;
        _suggestions = null;
        _issueDetailsVisible = false;
        StateHasChanged();
    }

    private void IgnoreSpellingViolation()
    {
        if (_currentIssue != null)
            CodeReviewService.RemoveLogMessage(_currentIssue);

        _spellingPopoverOpen = false;
        _suggestions = null;
        StateHasChanged();
    }

    private void ShowSuggestions()
    {
        var word = ExtractMisspelledWord(_currentIssue);
        if (string.IsNullOrEmpty(word))
            return;

        var spellChecker = StyleCheckingService.GetSpellChecker();
        _suggestions = spellChecker?.Suggest(word) ?? [];
        StateHasChanged();
    }

    private void CloseSpellingPopover()
    {
        _spellingPopoverOpen = false;
        _suggestions = null;
        StateHasChanged();
    }

