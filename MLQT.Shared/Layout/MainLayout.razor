@using MLQT.Shared.Pages
@using DymolaInterface
@using OpenModelicaInterface
@using System.IO
@using System.Collections.Concurrent
@using System.Reflection
@using System.Runtime
@using static MLQT.Services.LoggingService
@using RevisionControl

@inherits LayoutComponentBase

@inject AppState NavState
@inject ILibraryDataService LibraryDataService
@inject IRepositoryService RepositoryService
@inject IFilePickerService FilePickerService
@inject IJSRuntime JSRuntime
@inject ICodeReviewService CodeReviewService
@inject IDialogService DialogService
@inject ISettingsService SettingsService
@inject ISnackbar Snackbar
@inject IStyleCheckingService StyleCheckingService
@inject IFileMonitoringService FileMonitoringService
@inject IExternalResourceService ExternalResourceService
@inject IPowerManagementService PowerManagementService

@implements IDisposable

<MudThemeProvider Theme="@_myTheme" @bind-IsDarkMode="@_isDarkMode" />
<MudDialogProvider BackdropClick="false" CloseOnEscapeKey="false" MaxWidth="MaxWidth.Large" />
<MudPopoverProvider />
<MudSnackbarProvider />

<style>
    .mud-layout {
        height: 100vh;
        width: 100vw;
        position: relative;
    }

    .mud-grid {
        width: 100%;
        height: 100%;
        display: flex;
        flex-wrap: wrap;
        box-sizing: border-box;
    }

    .mud-navmenu {
        margin: 0;
        height: 100%;
        position: relative;
        list-style: none;
        overscroll-behavior-y: contain;
    }

    @* Changes the font size for page controls at the bottom of a table *@
    .mud-table-pagination {
       font-size: 0.75rem;
    }

    @* Changes the size of the tabs *@
    .mud-tabs-tabbar .mud-tabs-tabbar-inner {
        min-height: 2rem;
    }

    .mud-tab {
        min-height: 2rem;
        font-size: 0.75rem;
    }

    @* Changes the border on text fields *@
    .mud-input.mud-input-outlined .mud-input-outlined-border {
        border-color: rgb(0,0,0,0.118);
    }

    @* Changes the border on MudButtonGroups that don't have an explicit Color set *@
    @* Changes the padding for icons on text buttons to align the size with IconButtons *@
    .mud-button-group-outlined.mud-button-group-override-styles .mud-button-root {
        border-color: rgb(0,0,0,0.118);
        padding-top: 4px;
        padding-bottom: 4px;
    }
    
    .mud-button-outlined-size-small {
        padding-top: 4px !important;
        padding-bottom: 5px !important;
        font-size: 0.75rem !important;
    }

    @* Reduce the padding to account for the border and prevent the button from growing *@
    .mud-button-outlined.mud-button-outlined-primary {
        padding-left: 11px !important;
        padding-right: 11px !important;
    }

    @* Treeview adjustments to make more compact *@
    .mud-treeview-item-arrow {
        width: 0.8rem;
        margin: 0px;
    }

    .mud-treeview-item-icon {
        width: 1.5rem;
        margin-right: 0px;
        margin-inline-end: 0px;
    }

    /* Custom Modelica icon styles */
    .modelica-tree-icon {
        width: 20px;
        height: 20px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        margin-right: 4px;
        flex-shrink: 0;
    }

    .modelica-tree-icon svg {
        width: 100%;
        height: 100%;
    }

    .mud-treeview-item-checkbox {
        width: 1rem;
        height: 1rem;
    }

    .mud-treeview-item .mud-treeview-item-arrow .mud-icon-button{
        padding: 0px;
    }

    .mud-treeview-item-arrow .mud-icon-size-medium{
        width: 1rem !important;
        height: 1rem !important;
    }

    .mud-treeview-item-checkbox .mud-icon-size-medium{
        width: 1rem !important;
        height: 1rem !important;
    }

    .mud-treeview-item-checkbox .mud-icon-button{
        padding: 0px !important;
    }


    .mud-toolbar{
        --mud-internal-toolbar-height: 2rem;
    }

    .mud-table-toolbar{
        padding: 0.5rem;
        padding-inline-start: 0.5rem;
    }

    .compact-table {
        font-size: 0.625rem !important;
        font-family: var(--mud-typography-body1-family) !important;
        padding-top: 3px !important;
        padding-bottom: 3px !important;
    }

    .body1-table {
        font-size: var(--mud-typography-body1-size) !important;
        font-family: var(--mud-typography-body1-family) !important;
        padding-top: 4px !important;
        padding-bottom: 4px !important;
    }

    .body1-table-right {
        font-size: var(--mud-typography-body1-size) !important;
        font-family: var(--mud-typography-body1-family) !important;
        padding-top: 4px !important;
        padding-bottom: 4px !important;
        text-align: right !important;
    }

    .pre-wrap {
        white-space: pre-wrap;
    }

    .mud-picker .mud-typography-subtitle1 {
        font-size: var(--mud-typography-body1-size) !important;
        font-family: var(--mud-typography-body1-family) !important; 
    }

    .mud-input-control>.mud-input-control-input-container>.mud-input-label-inputcontrol {
        font-size: var(--mud-typography-body1-size) !important;
        font-family: var(--mud-typography-body1-family) !important; 
    }

    .mud-picker .mud-input-label-inputcontrol {
        transform: translate(0, 20px) scale(1);
    }

    .mud-toolbar-gutters {
